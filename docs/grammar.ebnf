(* Ollin — grammaire formelle
   Source de vérité : syntax.ol
   Maintenu par : Claude — mettre à jour après chaque évolution de syntax.ol

   Ce fichier est LA référence de la syntaxe et de la sémantique du langage.
   Les commentaires (* ... *) précisent les règles sémantiques attachées à
   chaque production. CLAUDE.md ne documente que l'implémentation interne.

   Terminateurs de statements : chaque statement se termine par un saut de ligne.
   À l'intérieur des parenthèses, crochets et accolades, les sauts de ligne
   sont ignorés (continuation implicite).
   Le caractère ';' est UNIQUEMENT le séparateur d'intervalle dans rangeLit.
   Un ';' hors d'un contexte entre crochets/parenthèses est une erreur. *)

program        = { stmt } EOF ;

stmt           = varDecl
               | globalDecl
               | constDecl
               | whileStmt
               | forStmt
               | ifStmt
               | tryStmt
               | throwStmt
               | funcDecl
               | classDecl
               | returnStmt
               | importStmt
               | assignStmt
               | exprStmt ;

importStmt     = "import" STRING [ "as" IDENT ] NL ;

classDecl      = "class" IDENT [ "extends" IDENT ] NL { method } "end" NL ;
method         = [ "static" ] "func" IDENT "(" [ params ] ")" NL { stmt } "end" NL ;
                 (* sans "static" : méthode d'instance — premier param implicite "self" en R[0] *)
                 (* avec "static" : méthode de classe — pas de self, appelable via Classe.m() ou instance.m() *)
                 (* "func init(...)" = constructeur (toujours instance) *)
                 (* méthodes spéciales : init, __str, __add, __sub, __mul, __div, __mod, __neg, __eq, __lt, __le *)

methodCall     = expr "." IDENT "(" [ expr { "," expr } ] ")" ;
superCall      = "super" "." IDENT "(" [ expr { "," expr } ] ")" ;

varDecl        = "var" IDENT { "," IDENT } [ "=" expr { "," expr } ] NL ;
                 (* `var` est OBLIGATOIRE pour créer une variable, et ne crée que des locales *)
                 (* sans "=" → nil ; moins de valeurs que de noms → les noms en trop valent nil *)
globalDecl     = "global" IDENT { "," IDENT } [ "=" expr { "," expr } ] NL ;
                 (* `global` déclare des variables globales, visibles dans tout le programme *)
                 (* déclarable n'importe où (top-level ou dans une fonction) ; lue/écrite partout *)
                 (* une locale `var` de même nom masque le global dans sa portée *)
constDecl      = "const" IDENT { "," IDENT } "=" expr { "," expr } NL ;
                 (* `const` déclare une locale immuable ; initialisation obligatoire *)
                 (* toute tentative d'assignation ultérieure est une erreur de compilation *)
                 (* une constante peut être capturée en lecture seule par une closure *)
whileStmt      = "while" expr "do" { stmt } "end" NL ;
forStmt        = "for" IDENT "=" expr "," expr [ "," expr ] "do" { stmt } "end" NL
               | "for" IDENT [ "," IDENT ] "in" expr "do" { stmt } "end" NL ;
                 (* numérique : "for i=start,end[,step]" ; step optionnel, défaut 1 ; step<0 décompte *)
                 (* itérateur : "for v in it" → valeur primaire (élément pour array/range, clé pour map) *)
                 (*             "for k,v in it" → clé/index + valeur *)
                 (* itérables : array, map (snapshot), range ; "break" valide partout *)
ifStmt         = "if" expr "then" { stmt }
                 { "elseif" expr "then" { stmt } }
                 [ "else" { stmt } ]
                 "end" NL ;
tryStmt        = "try" { stmt } "catch" IDENT { stmt } [ "else" { stmt } ] "end" NL ;
throwStmt      = "throw" expr NL ;
funcDecl       = "func" IDENT "(" [ params ] ")" NL { stmt } "end" NL ;
params         = param { "," param } [ "," "..." ] | "..." ;
param          = IDENT [ "=" literal ] ;
returnStmt     = "return" [ retvals ] NL ;
retvals        = "..."
               | expr { "," expr } [ "," "..." ] ;
assignStmt     = IDENT ( "=" | "+=" | "-=" | "*=" | "/=" | "%=" ) expr NL ;
                 (* règle sémantique : IDENT doit avoir été déclaré par "var" ou "global" — sinon erreur *)
                 (* "var" → locale ; "global" → globale (table VM partagée) *)
indexAssign    = IDENT "[" expr "]" ( "=" | "+=" | "-=" | "*=" | "/=" | "%=" ) expr NL
               | IDENT "." IDENT   ( "=" | "+=" | "-=" | "*=" | "/=" | "%=" ) expr NL ;
exprStmt       = expr NL ;

expr           = logical ;
logical        = logicalAnd { "or" logicalAnd } ;
logicalAnd     = bitwiseOr { "and" bitwiseOr } ;
bitwiseOr      = bitwiseXor { "|" bitwiseXor } ;
bitwiseXor     = bitwiseAnd { "^" bitwiseAnd } ;
bitwiseAnd     = comparison { "&" comparison } ;
comparison     = shift { ( ">" | "<" | ">=" | "<=" | "==" | "<>" ) shift } ;
             (* comparaisons chaînées : 1 < x < 10  ≡  (1 < x) and (x < 10), x évalué une fois *)
shift          = additive { ( "<<" | ">>" ) additive } ;
additive       = multiplicative { ( "+" | "-" ) multiplicative } ;
             (* "+" : addition numérique ou concaténation de strings *)
             (* promotion : INT op INT → INT ; INT op FLOAT → FLOAT ; "/" → toujours FLOAT *)
             (* overflow int64 → wrapping silencieux *)
multiplicative = power { ( "*" | "/" | "//" | "%" ) power } ;
             (* "//" : division entière plancher (floor) — INT//INT → INT, FLOAT//FLOAT → FLOAT *)
power          = unary ( "**" power ) ? ;
             (* "**" : exponentiation, associatif à droite — INT**INT(≥0) → INT ; sinon FLOAT *)
             (* 2**2**3 = 2**(2**3) = 256 *)
unary          = ( "-" | "not" | "~" ) unary | primary ;
primary        = NUMBER
               | STRING
               | BOOL
               | NIL
               | "super" "." IDENT "(" [ expr { "," expr } ] ")"
               | IDENT { ( "[" expr "]" | "." IDENT [ "(" [ expr { "," expr } ] ")" ] ) }
               | call  { ( "[" expr "]" | "." IDENT [ "(" [ expr { "," expr } ] ")" ] ) }
               | mapLit { ( "[" expr "]" | "." IDENT [ "(" [ expr { "," expr } ] ")" ] ) }
               | arrayLit { ( "[" expr "]" ) }
               | rangeLit
               | lambdaExpr
               | "..."
               | "(" expr ")" ;

lambdaExpr     = "func" "(" [ params ] ")" NL { stmt } "end" ;
               (* fonction anonyme utilisable comme expression ; capture des upvalues comme toute closure *)
               (* "expr.method(args)" = appel de méthode avec self implicite *)

mapLit         = "{" [ mapEntry { "," mapEntry } ] "}" ;
               (* sauts de ligne autorisés entre les entrées — la continuation implicite s'applique à l'intérieur de {} *)
mapEntry       = ( STRING | IDENT ) ":" expr ;
                 (* littéral : clés string ou identifiant ; à l'exécution toute Value peut être clé *)
                 (* accès : m["k"] et m.k sont équivalents (lecture, écriture, compound) *)
                 (* sémantique de copie : référence comptée (pas de clone) ; map toujours truthy *)
arrayLit       = "[" [ expr { "," expr } ] "]" ;
rangeLit       = ( "[" | "]" ) expr ";" expr [ ";" expr ] ( "]" | "[" ) ;
             (* [a;b] incl-incl, [a;b[ incl-excl, ]a;b] excl-incl, ]a;b[ excl-excl *)
             (* step optionnel [a;b;step] ; les ranges sont first-class et itérables *)
call           = IDENT "(" [ expr { "," expr } ] ")" ;

line_comment   = "##" { any \ newline } ;
block_comment  = "###" { any } "###" ;

(* NL : saut de ligne — termine tout statement.
   La continuation implicite s'applique à l'intérieur des parenthèses, crochets
   et accolades : un saut de ligne n'y termine pas le statement.
   ';' est le séparateur d'intervalle dans rangeLit ; interdit partout ailleurs. *)

NUMBER         = ( digit { [ "_" ] digit } [ "." { digit | "_" } ] )
               | ( "." digit { [ "_" ] digit } ) ;
             (* underscores ignorés : 1_000 == 1000 ; littéraux entiers → int48, sinon float *)
STRING         = '"' { any \ '"' } '"' ;
BOOL           = "true" | "false" ;
NIL            = "nil" ;
IDENT          = ( letter | "_" ) { letter | digit | "_" } ;

digit          = "0" | ... | "9" ;
letter         = "a" | ... | "z" | "A" | ... | "Z" ;
