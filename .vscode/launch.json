{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug tau (test.tau)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/tau",
            "args": ["${workspaceFolder}/test.tau"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cmake: build",
            "terminal": "integrated",
            "internalConsoleOptions": "neverOpen",
            "postRunCommands": ["breakpoint delete --force 1", "breakpoint delete --force 2"]
        }
    ]
}
