{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake: configure",
            "type": "shell",
            "command": "cmake -B build -DCMAKE_BUILD_TYPE=Release -DOLLIN_NATIVE_RAYLIB=ON",
            "presentation": { "reveal": "silent", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "cmake: build",
            "type": "shell",
            "command": "cmake -B build -DCMAKE_BUILD_TYPE=Release -DOLLIN_NATIVE_RAYLIB=ON && cmake --build build",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "silent", "panel": "shared" },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "ollin: run",
            "type": "shell",
            "command": "${workspaceFolder}/build/ollin \"${file}\"",
            "dependsOn": ["cmake: build"],
            "group": { "kind": "test", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        },
        {
            "label": "wasm: build",
            "type": "shell",
            "command": "bash tools/build-wasm.sh",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": []
        }
    ]
}