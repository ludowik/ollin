### test.tau — fichier de tests libres (Claude)
    Couvre toutes les constructions de syntax.tau
###

## ── strings ──────────────────────────────────────────────────────────────────
print("hello world!")        ## hello world!
print("tau v0.1")            ## tau v0.1

## ── arithmétique ─────────────────────────────────────────────────────────────
var x = 2 + 3 * 4
print(x)                     ## 14  (priorité * avant +)

var a, b = 10, 3
print(a - b)                 ## 7

## ── déclaration multiple ─────────────────────────────────────────────────────
var p, q = 6, 7
print(p)                     ## 6
print(q)                     ## 7

## ── while + break ────────────────────────────────────────────────────────────
var i = 0
while true
    i += 1
    if i > 4 break
end
print(i)                     ## 5

## ── while avec condition ─────────────────────────────────────────────────────
var sum = 0
var k = 1
while k < 10
    sum += k
    k += 1
end
print(sum)                   ## 45  (1+2+…+9)

## ── booleans ─────────────────────────────────────────────────────────────────
print(true)                  ## 1
print(false)                 ## 0

## ── expression parenthésée ───────────────────────────────────────────────────
print(2 * (3 + 4))           ## 14
