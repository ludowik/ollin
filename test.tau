### test.tau — fichier de tests libres (Claude)
    Couvre toutes les constructions de syntax.tau
###

## ── strings ──────────────────────────────────────────────────────────────────
print("hello world!")        ## hello world!

## ── arithmétique ─────────────────────────────────────────────────────────────
var x = 2 + 3 * 4
print(x)                     ## 14

var a, b = 10, 3
print(a - b)                 ## 7

## ── déclaration multiple ─────────────────────────────────────────────────────
var p, q = 6, 7
print(p)                     ## 6
print(q)                     ## 7

## ── booleans via variables ───────────────────────────────────────────────────
var vrai = true
var faux = false
print(vrai)                  ## 1
print(faux)                  ## 0

## ── if then end ──────────────────────────────────────────────────────────────
var n = 5
if n > 3 then
    print("n > 3")           ## n > 3
end

if faux then
    print("jamais")
end

## ── while + if + break ───────────────────────────────────────────────────────
var i = 0
while vrai
    i += 1
    if i > 4 then break end
end
print(i)                     ## 5

## ── while avec condition ─────────────────────────────────────────────────────
var sum = 0
var k = 1
while k < 10
    sum += k
    k += 1
end
print(sum)                   ## 45

## ── time ────────────────────────────────────────────────────────────────────
var t = time()
print(t)                     ## heure courante en secondes (Unix timestamp)

## ── try/catch/throw → catch exécuté ─────────────────────────────────────────
try
    throw "oulala"
catch err
    print(err)               ## error
else
    print("no error")
end

## ── try sans throw → else exécuté ───────────────────────────────────────────
try
    var ok = true
catch err
    print("caught")
else
    print("all good")        ## all good
end

## ── try vide, catch vide, sans else ─────────────────────────────────────────
try
catch err
end
