{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Ollin",
    "scopeName": "source.ollin",
    "patterns": [
        { "include": "#block_comment" },
        { "include": "#line_comment" },
        { "include": "#string" },
        { "include": "#keyword" },
        { "include": "#builtin" },
        { "include": "#number" },
        { "include": "#operator" }
    ],
    "repository": {
        "block_comment": {
            "name": "comment.block.ollin",
            "begin": "###",
            "end": "###"
        },
        "line_comment": {
            "name": "comment.line.ollin",
            "match": "##(?!#).*$"
        },
        "string": {
            "name": "string.quoted.double.ollin",
            "begin": "\"",
            "end": "\""
        },
        "keyword": {
            "name": "keyword.control.ollin",
            "match": "\\b(var|global|const|while|do|for|in|if|then|elseif|end|break|true|false|nil|try|catch|throw|else|func|return|import|as|or|and|not|class|extends|static|super|self|switch|case)\\b"
        },
        "builtin": {
            "name": "support.function.builtin.ollin",
            "match": "\\b(print|printf|time|assert|math|graphics|string)\\b"
        },
        "number": {
            "name": "constant.numeric.ollin",
            "match": "(\\.\\d[\\d_]*|\\b\\d[\\d_]*(\\.\\d[\\d_]*)?)\\b"
        },
        "operator": {
            "name": "keyword.operator.ollin",
            "match": "\\*\\*|//|\\+=|-=|\\*=|/=|%=|==|>=|<=|<>|<<|>>|\\.\\.\\.|\\.\\.|[+\\-*/%><&|^~]|[\\[\\]{}:.]"
        }
    }
}
