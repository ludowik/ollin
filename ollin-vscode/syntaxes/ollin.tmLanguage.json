{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Ollin",
    "scopeName": "source.ollin",
    "patterns": [
        { "include": "#block_comment" },
        { "include": "#line_comment" },
        { "include": "#string" },
        { "include": "#keyword" },
        { "include": "#builtin" },
        { "include": "#number" },
        { "include": "#operator" }
    ],
    "repository": {
        "block_comment": {
            "name": "comment.block.ollin",
            "begin": "###",
            "end": "###"
        },
        "line_comment": {
            "name": "comment.line.ollin",
            "match": "##(?!#).*$"
        },
        "string": {
            "name": "string.quoted.double.ollin",
            "begin": "\"",
            "end": "\""
        },
        "keyword": {
            "name": "keyword.control.ollin",
            "match": "\\b(var|while|if|then|end|break|true|false|try|catch|throw|else)\\b"
        },
        "builtin": {
            "name": "support.function.builtin.ollin",
            "match": "\\b(print|time)\\b"
        },
        "number": {
            "name": "constant.numeric.ollin",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        "operator": {
            "name": "keyword.operator.ollin",
            "match": "\\+=|[+\\-*/><]"
        }
    }
}
