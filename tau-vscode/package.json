{
    "name": "tau-language",
    "displayName": "Tau Language",
    "description": "Syntax highlighting for the Tau scripting language",
    "version": "0.0.1",
    "engines": { "vscode": "^1.70.0" },
    "contributes": {
        "languages": [{
            "id": "tau",
            "aliases": ["Tau", "tau"],
            "extensions": [".tau"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "tau",
            "scopeName": "source.tau",
            "path": "./syntaxes/tau.tmLanguage.json"
        }]
    }
}
